{
  "name": "aidi-studio-monorepo",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "setup": "supabase db push",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:api": "npm run dev --workspace apps/api",
