+const METRIC_SAMPLE: ShapedRow[] = [{ value: 18200 }];
+const RANGE_METRIC_SAMPLE: ShapedRow[] = [{ value: 68 }];
+
+export function sampleRowsFor(type: WidgetType): ShapedRow[] {
+  switch (type) {
