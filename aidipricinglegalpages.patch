+            <th>Why</th>
+          </tr>
+        </thead>
+        <tbody>
+          <tr>
+            <td>
+              <strong>Account data</strong>
+            </td>
+            <td>Email address, display name, hashed password (managed by our auth provider)</td>
+            <td>Sign-in, account recovery, service emails</td>
+          </tr>
+          <tr>
+            <td>
