SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SECRET_KEY="sb_secret_..."
PORT=4000
CORS_ORIGIN="http://localhost:5173"
SUPABASE_DB_URL=""
GROQ_API_KEY="gsk_..."
GROQ_MODEL="llama-3.3-70b-versatile"

# Only used by `npm run setup` (scripts/setup-supabase.js) to apply
# supabase/migrations/*.sql — not read by the server itself.
# Project Settings > Database > Connection string > Transaction pooler.
# SUPABASE_DB_URL="postgresql://postgres.your-project-ref:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres"

# Optional. Powers real AI widget suggestions in the builder (an open-source
# model — Llama 3.3 by default — served free via Groq's OpenAI-compatible
# API: https://console.groq.com/keys). Leave unset and the builder falls back
# to a deterministic, data-aware heuristic — no error, just a less clever
# suggestion (the UI labels which one ran).
# GROQ_API_KEY="gsk_..."
# GROQ_MODEL="llama-3.3-70b-versatile"
