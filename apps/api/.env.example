SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
SUPABASE_SECRET_KEY="sb_secret_..."
PORT=4000
CORS_ORIGIN="http://localhost:5173"

# Only used by `npm run setup` (scripts/setup-supabase.sh), not by the server itself.
# SUPABASE_ACCESS_TOKEN=sbp_...      # alternative to `npx supabase login`
# SUPABASE_DB_PASSWORD=...           # lets `supabase link` run non-interactively
